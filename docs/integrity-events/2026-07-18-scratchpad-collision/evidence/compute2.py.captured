import pickle
from datetime import date
data=pickle.load(open("/tmp/claude-0/-home-user-family-office-state/607d00af-9bdb-5e79-8e74-5a5bb311c2be/scratchpad/data2.pkl","rb"))
def dur(e):
    sy,sm,sd=map(int,e["start"].split("-")); ey,em,ed=map(int,e["end"].split("-"))
    return (date(ey,em,ed)-date(sy,sm,sd)).days
def merge_flow(lst):
    # end-year label -> value, preferring earlier tags in priority
    out={}; ends={}
    for tag,ent in lst:
        for e in ent:
            if "start" not in e: continue
            if not (350<=dur(e)<=380): continue
            y=int(e["end"][:4])
            if y not in out:  # first tag (higher priority) wins; within tag latest filed
                pass
            # keep per (y) the value; prefer existing (from higher-priority tag). If same tag multiple filings, take latest filed
            key=y
            if key not in out:
                out[key]=(e["val"],e["end"],tag,e.get("filed",""))
            else:
                pv=out[key]
                # same priority tag? only overwrite if same tag and newer filing
                if pv[2]==tag and e.get("filed","")>pv[3]:
                    out[key]=(e["val"],e["end"],tag,e.get("filed",""))
                # if pv from higher priority tag, keep
    return {y:v[0] for y,v in out.items()}, {y:(v[1],v[2]) for y,v in out.items()}
def merge_inst(lst):
    out={}
    for tag,ent in lst:
        for e in ent:
            if "start" in e: continue
            y=int(e["end"][:4]); key=y
            if key not in out:
                out[key]=(e["val"],e["end"],tag,e.get("filed",""))
            else:
                pv=out[key]
                if pv[2]==tag and e.get("filed","")>pv[3]:
                    out[key]=(e["val"],e["end"],tag,e.get("filed",""))
    return {y:v[0] for y,v in out.items()}, {y:(v[1],v[2]) for y,v in out.items()}
flowkeys={"rev","cor","oi","cfo","ni","da"}
M={}; META={}
for tk in data:
    M[tk]={}; META[tk]={}
    for k,lst in data[tk].items():
        if k in flowkeys: m,meta=merge_flow(lst)
        else: m,meta=merge_inst(lst)
        M[tk][k]=m; META[tk][k]=meta
def v(tk,k,y): return M[tk][k].get(y)
rows=[]
for tk in data:
    # latest FY = max end-year present in assets (balance sheet always filed)
    yrsA=M[tk]["assets"].keys(); yrsOI=M[tk]["oi"].keys()
    L=max(yrsA) if yrsA else (max(yrsOI) if yrsOI else None)
    def pct(x): return "未能核验" if x is None else f"{x*100:.1f}%"
    def rr(x): return "未能核验" if x is None else f"{x:.2f}"
    def gm(y):
        r=v(tk,"rev",y); c=v(tk,"cor",y)
        if r is None: return "未能核验"
        if c is None: return "n/a(服务业无COGS口径)"
        return f"{(r-c)/r*100:.1f}%"
    gm20=gm(2020); gmL=gm(L)
    oi=v(tk,"oi",L); assets=v(tk,"assets",L); cl=v(tk,"curliab",L)
    gw=v(tk,"goodwill",L) or 0; it=v(tk,"intang",L) or 0
    roic=troic=None; tic=None
    if oi is not None and assets is not None and cl is not None:
        ic=assets-cl
        if ic: roic=oi*0.79/ic
        tic=assets-cl-gw-it
        if tic: troic=oi*0.79/tic
    da=v(tk,"da",L); ltdn=v(tk,"ltd_nc",L); ltdc=v(tk,"ltd_c",L); cash=v(tk,"cash",L)
    nde=None
    if oi is not None and da is not None:
        eb=oi+da; nd=(ltdn or 0)+(ltdc or 0)-(cash or 0)
        if eb: nde=nd/eb
    cfo=v(tk,"cfo",L); ni=v(tk,"ni",L); cfoni=cfo/ni if (cfo is not None and ni) else None
    flags=[]
    if tic is not None and tic<0: flags.append("有形净资产为负")
    if da is None: flags.append("D&A缺失")
    if ltdn is None and ltdc is None: flags.append("无长期债务标签")
    if oi is None: flags.append("无OperatingIncome标签")
    if cash is None: flags.append("现金标签缺失")
    rows.append((tk,gm20,f"{gmL} (FY{L})",rr(roic),rr(troic),rr(nde),rr(cfoni),"; ".join(flags)))
    print(f"DBG {tk} L={L} oi={oi} da={da} ltdn={ltdn} ltdc={ltdc} cash={cash} ni={ni} cfo={cfo} rev20={v(tk,'rev',2020)} cor20={v(tk,'cor',2020)} corL={v(tk,'cor',L)} oi_years={sorted(M[tk]['oi'].keys())}")
print("\n=== TABLE ===")
print("| Ticker | GM FY2020 | GM latest (FY yr) | ROIC | Tangible ROIC | ND/EBITDA | CFO/NI | flags |")
print("|---|---|---|---|---|---|---|---|")
for r in rows: print("| "+" | ".join(r)+" |")
