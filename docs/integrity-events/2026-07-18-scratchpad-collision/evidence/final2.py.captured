import subprocess, json, os
from datetime import date
CACHE="/tmp/claude-0/-home-user-family-office-state/607d00af-9bdb-5e79-8e74-5a5bb311c2be/scratchpad/edgar"
UA="family-office-research yxy2660@gmail.com"
companies=[("CMG","0001058090"),("ORLY","0000898173"),("AZO","0000866787"),("TJX","0000109198"),
("ROST","0000745732"),("NKE","0000320187"),("LULU","0001397187"),("BKNG","0001075531"),
("CPRT","0000900075"),("ROL","0000084839"),("MAR","0001048286"),("HLT","0001585689"),
("YUM","0001041061"),("DPZ","0001286681"),("ULTA","0001403568"),("DECK","0000910521"),
("RL","0001037038"),("TPR","0001116132"),("SBUX","0000829224"),("DRI","0000940944"),
("ABNB","0001559720"),("EXPE","0001324424")]
concepts={
 "rev":["RevenueFromContractWithCustomerExcludingAssessedTax","RevenueFromContractWithCustomerIncludingAssessedTax","Revenues","SalesRevenueNet"],
 "cor":["CostOfGoodsAndServicesSold","CostOfRevenue","CostOfGoodsSold"],
 "oi":["OperatingIncomeLoss"],"assets":["Assets"],"curliab":["LiabilitiesCurrent"],
 "goodwill":["Goodwill"],"intang":["IntangibleAssetsNetExcludingGoodwill"],
 "cfo":["NetCashProvidedByUsedInOperatingActivities"],"ni":["NetIncomeLoss"],
 "da":["DepreciationDepletionAndAmortization","DepreciationAmortizationAndAccretionNet"],
 "ltd_nc":["LongTermDebtNoncurrent"],"ltd_c":["LongTermDebtCurrent"],
 "cash":["CashAndCashEquivalentsAtCarryingValue"]}
def fetch(cik,tag):
    fn=os.path.join(CACHE,f"{cik}_{tag}.json")
    if os.path.exists(fn) and os.path.getsize(fn)>0: return open(fn).read()
    return ""
def entries(txt):
    try: d=json.loads(txt)
    except: return []
    if not isinstance(d,dict) or "units" not in d or "USD" not in d["units"]: return []
    return [e for e in d["units"]["USD"] if e.get("form")=="10-K"]
def dur(e):
    sy,sm,sd=map(int,e["start"].split("-")); ey,em,ed=map(int,e["end"].split("-"))
    return (date(ey,em,ed)-date(sy,sm,sd)).days
def build(lst, flow):
    fymap={}; bydate={}
    for prio,(tag,ent) in enumerate(lst):
        byfy={}
        for e in ent:
            if e.get("fp")!="FY" or e.get("fy") is None: continue
            if flow:
                if "start" not in e or not (350<=dur(e)<=380): continue
            else:
                if "start" in e: continue
            byfy.setdefault(e["fy"],[]).append(e)
            d=bydate.get(e["end"])
            if d is None or prio<d[1]:
                bydate[e["end"]]=(e["val"],prio)
        for fy,es in byfy.items():
            es.sort(key=lambda x:(x["end"],x.get("filed","")))
            c=es[-1]
            cur=fymap.get(fy)
            if cur is None or prio<cur[2]:
                fymap[fy]=(c["val"],c["end"],prio)
    return ({fy:o[0] for fy,o in fymap.items()},
            {fy:o[1] for fy,o in fymap.items()},
            {dt:o[0] for dt,o in bydate.items()})
data={}
for tk,cik in companies:
    data[tk]={}
    for k,tags in concepts.items():
        lst=[(t,entries(fetch(cik,t))) for t in tags]
        lst=[(t,e) for t,e in lst if e]
        data[tk][k]=build(lst, k in {"rev","cor","oi","cfo","ni","da"})
M={tk:{k:v[0] for k,v in d.items()} for tk,d in data.items()}
END={tk:{k:v[1] for k,v in d.items()} for tk,d in data.items()}
BD={tk:{k:v[2] for k,v in d.items()} for tk,d in data.items()}
def v(tk,k,fy): return M[tk][k].get(fy)
rows=[]
for tk in M:
    La=max(M[tk]["assets"].keys()) if M[tk]["assets"] else None
    Lr=max(M[tk]["rev"].keys()) if M[tk]["rev"] else None
    def rr(x): return "未能核验" if x is None else f"{x:.2f}"
    # ABNB special: fy2020 skipped -> read by end date 2020-12-31
    def rev_fy(fy, byd=None):
        if byd: return BD[tk]["rev"].get(byd)
        return v(tk,"rev",fy)
    def cor_fy(fy, byd=None):
        if byd: return BD[tk]["cor"].get(byd)
        return v(tk,"cor",fy)
    abnb2020 = "2020-12-31" if tk=="ABNB" else None
    def gm(r,c):
        if r is None: return "未能核验"
        if c is None: return "n/a(无COGS口径)"
        return f"{(r-c)/r*100:.1f}%"
    gm20=gm(rev_fy(2020,abnb2020), cor_fy(2020,abnb2020))
    gmL=gm(v(tk,"rev",Lr), v(tk,"cor",Lr))
    # ROIC block uses assets-fy La
    oi=v(tk,"oi",La); assets=v(tk,"assets",La); cl=v(tk,"curliab",La)
    gw=v(tk,"goodwill",La) or 0; it=v(tk,"intang",La) or 0
    roic=troic=None; tic=None
    if oi is not None and assets is not None and cl is not None:
        ic=assets-cl
        if ic: roic=oi*0.79/ic
        tic=assets-cl-gw-it
        if tic: troic=oi*0.79/tic
    da=v(tk,"da",La); ltdn=v(tk,"ltd_nc",La); ltdc=v(tk,"ltd_c",La); cash=v(tk,"cash",La)
    nde=None
    if oi is not None and da is not None:
        eb=oi+da; nd=(ltdn or 0)+(ltdc or 0)-(cash or 0)
        if eb: nde=nd/eb
    cfo=v(tk,"cfo",La); ni=v(tk,"ni",La)
    cfoni=cfo/ni if (cfo is not None and ni) else None
    flags=[]
    if tic is not None and tic<0: flags.append("有形净资产为负")
    if oi is None: flags.append("无OI标签")
    if da is None: flags.append("D&A缺失")
    if ltdn is None and ltdc is None: flags.append("无长期债务标签")
    if cash is None: flags.append("现金缺失")
    rows.append((tk,gm20,f"{gmL} (FY{Lr})",rr(roic),rr(troic),rr(nde),rr(cfoni),"; ".join(flags)))
print("| Ticker | GM FY2020 | GM latest (FY yr) | ROIC | Tangible ROIC | ND/EBITDA | CFO/NI | flags |")
print("|---|---|---|---|---|---|---|---|")
for r in rows: print("| "+" | ".join(r)+" |")
